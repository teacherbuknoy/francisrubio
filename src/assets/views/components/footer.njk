<noscript>
  <nav class="show-on-mobile navigation-bar__section padding gap--m" style="flex-direction: column;" id="noscript-nav">
    <h2 style="text-transform: uppercase;font-variation-settings: 'wght' 700;" class="margin--none fs-6 font-sans">Navigation</h2>
    <ul class="navigation-list gap--m">
      {% for item in navigation | rejectattr("overflow") %}
        <li class="navigation-list-item">
          <a href="{{ item.url }}" class="button button--small">
            {% if item.feathericon %}
              {{ icon(feathericon) }}
            {% endif %}

            {% if item.text %}
              <span>{{ item.text }}</span>
            {% elif item.label %}
              <span>{{ item.label }}</span>
            {% endif %}
          </a>
        </li>
      {% endfor %}
    </ul>
  </nav>
</noscript>
<div class="bottom-fixed">
  <a href="#top" class="primary button go-to-top" style="">
    {{ 'arrow-up' | icon | safe }}
    <span class="sr-only">Back to top</span>
  </a>
  <noscript class="no-js__warning">
    <p>JavaScript is not enabled on the browser you're using. Some features won't work.</p>
  </noscript>
</div>
<footer class="footer" id="main-footer">
  <div class="footer__header webring font-sans">
    <p>This website is part of the <a href="https://webring.antaresph.dev/">Pinoy Websites</a> web ring.</p>
    <p>
      <a href="https://webring.antaresph.dev/previous">Previous site</a>.
      <a href="https://webring.antaresph.dev/random">Random site</a>.
      <a href="https://webring.antaresph.dev/next">Next site</a>.
    </p>
  </div>
  <div class="footer__header font-sans">
    <p>&copy; {{ "" | year }} Francis Rubio. All rights reserved.</p>
    <p>Powered by <a href="https://11ty.dev">Eleventy</a> and <a href="https://vercel.com">Vercel</a>.</p>
  </div>
  <div class="footer__body">
    <div class="footer__section">
      <div class="cluster ai--center gap--m">
        <h2 class="responsive fs-4 font-sans weight-700 fg-primary-900" style="margin: 0;">
          <span class="visually-hidden">Francis Rubio</span>
          <span aria-hidden="true" class="logo-type">francisrub<span class="logo-dot">.</span>io</span>
        </h2>
      </div>
      <p style="margin: 0; font-family: var(--font-sans);">Web designer, developer, and educator from the Philippines.</p>
      <img class="not-by-ai hide-on-dark" src="/assets/images/not-by-ai/black.png" alt="Content in this site is purely produced, written, and created by humans, not by artificial intelligence.">
      <img class="not-by-ai hide-on-light" src="/assets/images/not-by-ai/white.png" alt="Content in this site is purely produced, written, and created by humans, not by artificial intelligence.">
    </div>
    <div class="footer__section" id="footer-contact">
      <h2 class="footer__section-title">Contact Me</h2>
      <ul class="button-list">
        {% for item in site.contact | notHidden %}
          <li class="button-list__item">
            <a href="{{ item.url }}" class="button button--small">{{ item.name }}</a>
          </li>
        {% endfor %}
      </ul>
    </div>
    <div class="footer__section" id="footer-press-kit">
      <h2 class="footer__section-title">Links</h2>
      <ul class="button-list">
        <li class="button-list__item">
          <a href="/speaking/information-for-event-organizers/" class="button button--small">For event organizers</a>
        </li>
        <li class="button-list__item">
          <a href="/press-kit/" class="button button--small">Press kit</a>
        </li>
        <li class="button-list__item">
          <a href="https://webring.antaresph.dev/" target="_blank" rel="noopener" class="button button--small">Pinoy Websites</a>
        </li>
      </ul>
    </div>
    <noscript class="footer__section" id="footer-overflow-menu">
      <h2 class="footer__section-title">On this site</h2>
      <ul class="button-list">
        {% for item in navigation | selectattr("overflow") %}
          <li class="button-list__item">
            <a href="{{ item.url }}" class="button button--small">
              {% if item.feathericon %}
                {{ icon(feathericon) }}
              {% endif %}

              {% if item.text %}
                <span>{{ item.text }}</span>
              {% elif item.label %}
                <span>{{ item.label }}</span>
              {% endif %}
            </a>
          </li>
        {% endfor %}
      </ul>
    </noscript>
    <noscript class="footer__section" id="footer-rss">
      <h2 class="footer__section-title">RSS Feeds</h2>
      <ul class="button-list">
        {% for item in site.feeds | values %}
          <li class="button-list__item">
            <a href="{{ item.url }}" class="button button--small">{{ item.label }}</a>
          </li>
        {% endfor %}
        <li class="button-list__item">
          <a href="https://rss.com/blog/how-do-rss-feeds-work/" target="_blank" rel="noopener" class="button button--small">How do I use this?</a>
        </li>
      </ul>
    </noscript>
  </div>
</footer>
